# === Passenger Configuration ===
PassengerAppRoot /home/u608187177/domains/arundevstudio.com/nodejs
PassengerAppType node
PassengerNodejs /opt/alt/alt-nodejs22/root/bin/node
PassengerStartupFile server.js
PassengerBaseURI /
PassengerRestartDir /home/u608187177/domains/arundevstudio.com/nodejs/tmp
SetEnv NODE_OPTIONS "--require /home/u608187177/domains/arundevstudio.com/public_html/.builds/config/preload-timestamp.js"
SetEnv LSNODE_CONSOLE_LOG console.log
SetEnv TOKIO_WORKER_THREADS 2
RewriteRule ^\.builds - [F,L]

# === LiteSpeed Cache & Optimization Control ===
# Disable ALL LiteSpeed caching and optimization to prevent stale HTML after deployments
<IfModule LiteSpeed>
  CacheDisable public /
  CacheDisable private /
  CacheLookup off
  RewriteEngine On
  RewriteRule .* - [E=Cache-Control:no-cache]
  RewriteRule .* - [E=Cache-Tag:no-cache]
</IfModule>

# Force no-cache on ALL responses to bypass LiteSpeed optimization layer
<IfModule mod_headers.c>
  Header always set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
  Header always set Pragma "no-cache"
  Header always set Expires 0
  Header always set X-LiteSpeed-Cache-Control "no-cache"
  Header always set X-LiteSpeed-Purge "*"
  Header always set Vary "Accept-Encoding"
</IfModule>

# Long-term caching ONLY for hashed static assets in _next directory
<Directory "*/_next/static/*">
  <IfModule mod_headers.c>
    Header set Cache-Control "public, max-age=31536000, immutable"
  </IfModule>
</Directory>

# Enable compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json application/xml text/xml
</IfModule>
